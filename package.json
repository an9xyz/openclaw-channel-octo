{
  "name": "octo",
  "version": "1.0.18",
  "description": "Octo channel plugin for OpenClaw",
  "license": "Apache-2.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "index.ts",
    "skills",
    "setup-entry.ts",
    "openclaw.plugin.json",
    "CHANGELOG.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "prebuild": "node -e \"const fs=require('fs'),v=require('./package.json').version; fs.rmSync('dist',{recursive:true,force:true}); fs.writeFileSync('src/version.ts','// Auto-generated by prebuild script. Do not edit manually.\\nexport const PLUGIN_VERSION = \\\"'+v+'\\\"; // x-release-please-version\\n')\"",
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepack": "npm run build",
    "pack:check": "npm pack --dry-run 2>&1 | tee /tmp/octo-pack.txt && grep -q 'dist/index.js' /tmp/octo-pack.txt && grep -q 'dist/setup-entry.js' /tmp/octo-pack.txt && echo '✓ dist/ included in tarball'"
  },
  "dependencies": {
    "axios": "^1.17.0",
    "crypto-js": "^4.2.0",
    "curve25519-js": "^0.0.4",
    "md5-typescript": "^1.0.5",
    "ws": "^8.21.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.4.15"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/crypto-js": "^4.2.0",
    "@types/ws": "^8.5.10",
    "openclaw": "^2026.6.5",
    "typescript": "^6.0.3",
    "vitest": "^3.0.0"
  },
  "openclaw": {
    "id": "octo",
    "type": "channel",
    "extensions": [
      "./index.ts"
    ],
    "runtimeExtensions": [
      "./dist/index.js"
    ],
    "setupEntry": "./setup-entry.ts",
    "runtimeSetupEntry": "./dist/setup-entry.js",
    "channel": {
      "id": "octo",
      "label": "Octo",
      "selectionLabel": "Octo",
      "detailLabel": "Octo Bot",
      "docsPath": "/channels/octo",
      "markdownCapable": false,
      "blurb": "Connect OpenClaw to Octo, an open-source team collaboration platform."
    },
    "install": {
      "clawhubSpec": "clawhub:octo",
      "defaultChoice": "clawhub",
      "minHostVersion": ">=2026.4.15"
    },
    "compat": {
      "pluginApi": ">=2026.4.15"
    },
    "build": {
      "openclawVersion": "2026.5.4"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": false
    }
  },
  "engines": {
    "node": ">=22"
  },
  "bundledDependencies": [
    "crypto-js",
    "curve25519-js",
    "md5-typescript"
  ]
}
